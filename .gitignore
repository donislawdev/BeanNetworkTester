__pycache__/
*.py[cod]
.pytest_cache/
build/
dist/
*.spec
!BeanNetworkTester.spec   # the build recipe IS part of the repo
.venv/
venv/
# files generated at runtime next to the app
bean_network_tester_profiles.json
bean_network_tester_stats.csv
bean_network_tester_ui.json
*.ndjson
bean_run.log
debug.log
.hypothesis/
.coverage
# coverage runs with parallel=true (pyproject), so each subprocess writes its own
# .coverage.<host>.<pid>.<rand>; --cov-report=xml (CI) writes coverage.xml. Neither
# is the bare ".coverage" above, so both must be listed or git add -A would grab them.
.coverage.*
coverage.xml
# runtime crash artefacts (never commit or ship)
crashes/
SHA256SUMS.txt
BeanNetworkTester-*.zip

# Claude config and dev notes - kept in the private BeanNetworkTester-Doc repo
.claude/
PROJECT_NOTES.md
HISTORY_NOTES.md
